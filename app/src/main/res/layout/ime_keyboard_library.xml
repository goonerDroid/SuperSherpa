<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/keyboard_background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/voice_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/voice_bar_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/voice_bar_ready"
            android:textColor="@color/brand_on_surface_variant"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/voice_bar_action"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_voice_bar_action"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="84dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/voice_bar_start"
            android:textColor="@color/voice_bar_action_text"
            android:textSize="16sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.frogobox.libkeyboard.ui.main.MainKeyboard
            android:id="@+id/keyboard_main"
            style="@style/FrogoKeyboardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/keyboard_background" />

        <com.frogobox.libkeyboard.ui.emoji.EmojiKeyboard
            android:id="@+id/keyboard_emoji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/keyboard_background"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
