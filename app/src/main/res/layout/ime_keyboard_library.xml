<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:background="@color/keyboard_background"
  android:orientation="vertical">

  <LinearLayout
    android:id="@+id/voice_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="10dp">

    <TextView
      android:id="@+id/voice_bar_status"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="@string/voice_bar_ready"
      android:textColor="@color/brand_on_surface_variant"
      android:textSize="16sp" />

    <FrameLayout
      android:id="@+id/voice_bar_action_container"
      android:layout_width="36dp"
      android:layout_height="36dp"
      android:layout_marginStart="12dp"
      android:clipChildren="false"
      android:clipToPadding="false"
      android:foregroundGravity="center">

      <View
        android:id="@+id/voice_bar_wave_outer"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_voice_bar_wave_ring"
        android:visibility="gone" />

      <View
        android:id="@+id/voice_bar_wave_inner"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_voice_bar_wave_ring"
        android:visibility="gone" />

      <View
        android:id="@+id/voice_bar_wave_mid"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_voice_bar_wave_ring"
        android:visibility="gone" />

      <ImageView
        android:id="@+id/voice_bar_action"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_voice_bar_action"
        android:clickable="true"
        android:contentDescription="@string/voice_bar_start"
        android:focusable="true"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_voice_bar_mic_24"
        app:tint="@color/voice_bar_action_text" />
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.frogobox.libkeyboard.ui.main.MainKeyboard
            android:id="@+id/keyboard_main"
            style="@style/FrogoKeyboardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/keyboard_background" />

        <com.frogobox.libkeyboard.ui.emoji.EmojiKeyboard
            android:id="@+id/keyboard_emoji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/keyboard_background"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
